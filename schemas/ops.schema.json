{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tipoLi5890/akcli/schemas/ops.schema.json",
  "title": "AkcliOpList",
  "type": "object",
  "required": ["protocol_version", "target_format", "ops"],
  "properties": {
    "protocol_version": { "const": 1 },
    "target_format": { "enum": ["kicad", "altium"] },
    "target_file": { "type": "string" },
    "run_id": { "type": "string" },
    "groups": {
      "type": "object",
      "description": "Functional groups (modules). Any op may carry an optional 'group': '<NAME>' tag referencing an entry here; the op's [x, y] coordinates are then GROUP-LOCAL and akcli translates them by the group's origin before validation (absolute = local + origin). Pin anchors ('REF.PIN', 'mid()') are position-independent and never translate. Membership is persisted on placed symbols as a hidden 'Group' property.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "origin": { "$ref": "#/$defs/point",
                      "description": "[x_mil, y_mil] world origin of the group's local coordinate frame." },
          "title": { "type": "string",
                     "description": "Human-readable module title (used by group frames)." },
          "frame": { "type": "boolean",
                     "description": "Hint that this group wants a visual border frame (see `akcli groups frame`)." }
        },
        "required": ["origin"],
        "additionalProperties": false
      }
    },
    "ops": { "type": "array", "items": { "$ref": "#/$defs/op" } }
  },
  "$defs": {
    "point": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
    "pinref": { "type": "string", "pattern": "^[^.]+\\.[^.]+$" },
    "midref": {
      "type": "string",
      "description": "mid(REF.PIN,REF.PIN): midpoint of two axis-aligned pins, snapped to the 50-mil grid along the wire axis.",
      "pattern": "^mid\\(\\s*[^,()\\s]+\\.[^,()\\s]+\\s*,\\s*[^,()\\s]+\\.[^,()\\s]+\\s*\\)$"
    },
    "endpoint": {
      "oneOf": [
        { "$ref": "#/$defs/point" },
        { "$ref": "#/$defs/pinref" }
      ]
    },
    "anchor": {
      "oneOf": [
        { "$ref": "#/$defs/point" },
        { "$ref": "#/$defs/pinref" },
        { "$ref": "#/$defs/midref" }
      ]
    },
    "rotation": { "enum": [0, 90, 180, 270] },
    "mirror": { "enum": ["none", "x", "y"] },
    "scope": { "enum": ["local", "global", "hierarchical"] },
    "strpair": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 },
    "strtriple": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 3 },
    "anchorref": {
      "type": "string",
      "description": "Relative-placement anchor: 'REF.PIN' (that pin's world coordinate) or bare 'REF' (the component origin). Resolved by the writer against the live document, so the anchor may be placed earlier in the SAME op-list. offset_mil is a world-frame [dx, dy] from the anchor; the result grid-snaps. Exactly one of x_mil/y_mil or anchor per op.",
      "pattern": "^[^.()\\s]+(\\.[^.()\\s]+)?$"
    },
    "op": {
      "type": "object",
      "required": ["op"],
      "oneOf": [
        {
          "properties": {
            "op": { "const": "place_component" },
            "lib_id": { "type": "string" },
            "designator": { "type": "string" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "anchor": { "$ref": "#/$defs/anchorref" },
            "offset_mil": { "$ref": "#/$defs/point" },
            "rotation": { "$ref": "#/$defs/rotation" },
            "mirror": { "$ref": "#/$defs/mirror" },
            "unit": { "type": "integer", "minimum": 1,
                      "description": "Unit of a multi-unit part to place (default 1); each unit is its own instance sharing the designator." },
            "value": { "type": "string" },
            "footprint": { "type": "string" },
            "symbol_source": { "type": "string" }
          },
          "required": ["op", "lib_id", "designator"],
          "description": "Position is exactly one of x_mil+y_mil (absolute) or anchor (+offset_mil, relative to a placed pin/component)."
        },
        {
          "properties": {
            "op": { "const": "delete_component" },
            "designator": { "type": "string" },
            "cascade": { "type": "boolean",
                         "description": "Also delete wires ending on a deleted pin plus labels/no_connects/junctions anchored there (cascaded uuids are reported)." }
          },
          "required": ["op", "designator"]
        },
        {
          "properties": {
            "op": { "const": "delete_object" },
            "uuid": { "type": "string" },
            "match": {
              "type": "object",
              "description": "Selector alternative to uuid; must match exactly one object (0 = replay-safe note, >1 = error listing candidates).",
              "properties": {
                "kind": { "enum": ["wire", "bus", "label", "global_label", "hierarchical_label", "junction", "no_connect", "text", "bus_entry", "rectangle", "text_box"] },
                "name": { "type": "string" },
                "at": { "$ref": "#/$defs/point" }
              },
              "required": ["kind"],
              "additionalProperties": false
            }
          },
          "required": ["op"],
          "oneOf": [
            { "required": ["uuid"] },
            { "required": ["match"] }
          ]
        },
        {
          "properties": {
            "op": { "const": "move_component" },
            "designator": { "type": "string" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "anchor": { "$ref": "#/$defs/anchorref" },
            "offset_mil": { "$ref": "#/$defs/point" },
            "unit": { "type": "integer", "minimum": 1 },
            "carry_labels": { "type": "boolean" },
            "carry_wires": { "type": "boolean" }
          },
          "required": ["op", "designator"],
          "description": "Destination is exactly one of x_mil+y_mil (absolute) or anchor (+offset_mil)."
        },
        {
          "properties": {
            "op": { "const": "set_component_transform" },
            "designator": { "type": "string" },
            "rotation": { "$ref": "#/$defs/rotation" },
            "mirror": { "$ref": "#/$defs/mirror" }
          },
          "required": ["op", "designator"]
        },
        {
          "properties": {
            "op": { "const": "set_component_parameters" },
            "designator": { "type": "string" },
            "reference": { "type": "string" },
            "value": { "type": "string" },
            "footprint": { "type": "string" },
            "parameters": { "type": "object" }
          },
          "required": ["op", "designator"]
        },
        {
          "properties": {
            "op": { "const": "add_wire" },
            "vertices": { "type": "array", "items": { "$ref": "#/$defs/endpoint" }, "minItems": 2 }
          },
          "required": ["op", "vertices"]
        },
        {
          "properties": {
            "op": { "const": "route_net" },
            "from": { "$ref": "#/$defs/endpoint" },
            "to": { "$ref": "#/$defs/endpoint" },
            "style": { "enum": ["auto", "hv", "vh", "z"],
                       "description": "Corner style: hv = horizontal-first L, vh = vertical-first L, z = 3 segments; auto (default) picks hv unless its corner lands on a pin tip, then vh, then z." },
            "label": { "type": "string",
                       "description": "Optional net name placed ONCE at the longest segment's midpoint (the wire_net pattern for non-coaxial pins)." },
            "scope": { "$ref": "#/$defs/scope" }
          },
          "required": ["op", "from", "to"],
          "description": "Deterministic orthogonal auto-route between two endpoints: coaxial -> straight wire; otherwise an L/Z whose corner provably avoids every placed pin tip (a coincident corner would silently merge nets)."
        },
        {
          "properties": {
            "op": { "const": "add_junction" },
            "at": { "$ref": "#/$defs/point" }
          },
          "required": ["op", "at"]
        },
        {
          "properties": {
            "op": { "const": "add_no_connect" },
            "pin": { "$ref": "#/$defs/endpoint" }
          },
          "required": ["op", "pin"]
        },
        {
          "properties": {
            "op": { "const": "add_net_label" },
            "name": { "type": "string" },
            "at": { "$ref": "#/$defs/anchor" },
            "scope": { "$ref": "#/$defs/scope" },
            "orientation": { "$ref": "#/$defs/rotation" }
          },
          "required": ["op", "name", "at"]
        },
        {
          "properties": {
            "op": { "const": "place_power_port" },
            "lib_id": { "type": "string" },
            "net_name": { "type": "string" },
            "at": { "$ref": "#/$defs/anchor" },
            "rotation": { "$ref": "#/$defs/rotation" }
          },
          "required": ["op", "lib_id", "net_name", "at"]
        },
        {
          "properties": {
            "op": { "const": "place_gnd" },
            "lib_id": { "type": "string" },
            "net_name": { "type": "string" },
            "at": { "$ref": "#/$defs/anchor" },
            "rotation": { "$ref": "#/$defs/rotation" }
          },
          "required": ["op", "at"]
        },
        {
          "properties": {
            "op": { "const": "place_vcc" },
            "lib_id": { "type": "string" },
            "net_name": { "type": "string" },
            "at": { "$ref": "#/$defs/anchor" },
            "rotation": { "$ref": "#/$defs/rotation" }
          },
          "required": ["op", "at"]
        },
        {
          "properties": {
            "op": { "const": "rename_net" },
            "from": { "type": "string" },
            "to": { "type": "string" },
            "scope": { "$ref": "#/$defs/scope",
                       "description": "Restrict the rewrite to one label kind; omitted = all label kinds + power-port net Values." }
          },
          "required": ["op", "from", "to"]
        },
        {
          "properties": {
            "op": { "const": "add_bus" },
            "vertices": { "type": "array", "items": { "$ref": "#/$defs/point" }, "minItems": 2 }
          },
          "required": ["op", "vertices"]
        },
        {
          "properties": {
            "op": { "const": "add_bus_entry" },
            "at": { "$ref": "#/$defs/point" },
            "size": { "$ref": "#/$defs/point" }
          },
          "required": ["op", "at"]
        },
        {
          "properties": {
            "op": { "const": "add_text" },
            "text": { "type": "string" },
            "at": { "$ref": "#/$defs/point" },
            "angle": { "type": "number" },
            "key": { "type": "string", "description": "Stable replacement handle: re-emitting the same key replaces this node in place regardless of coordinates or op-list position (group titles use group_title:<name>)." }
          },
          "required": ["op", "text", "at"]
        },
        {
          "properties": {
            "op": { "const": "add_rectangle" },
            "start": { "$ref": "#/$defs/point", "description": "One corner [x, y] mil of the box." },
            "end": { "$ref": "#/$defs/point", "description": "The opposite corner [x, y] mil." },
            "stroke_width_mil": { "type": "number", "description": "Border line width in mils (0 = KiCad default)." },
            "fill": { "enum": ["none", "outline", "background"] },
            "key": { "type": "string", "description": "Stable replacement handle: re-emitting the same key replaces this node in place regardless of coordinates or op-list position (group frames use group_frame:<name>)." }
          },
          "required": ["op", "start", "end"],
          "description": "Top-level graphic rectangle (pure annotation, connectivity-neutral): module borders / group frames. Delete by uuid or by kind (it has no `at` anchor, so the match `at` selector never hits a rectangle)."
        },
        {
          "properties": {
            "op": { "const": "add_text_box" },
            "text": { "type": "string", "description": "Note content; \\n for line breaks." },
            "at": { "$ref": "#/$defs/point", "description": "TOP-LEFT corner [x, y] mil of the box." },
            "size": { "$ref": "#/$defs/point", "description": "[width, height] mil." },
            "angle": { "type": "number" },
            "key": { "type": "string", "description": "Stable replacement handle (see add_rectangle.key)." }
          },
          "required": ["op", "text", "at", "size"],
          "description": "Bordered multi-line note box (module notes / design rationale). Pure annotation, connectivity-neutral; grammar fixture-verified against a real KiCad."
        },
        {
          "properties": {
            "op": { "const": "add_sheet" },
            "name": { "type": "string", "description": "Sheetname property value." },
            "file": { "type": "string", "description": "Sheetfile property value; the referenced child .kicad_sch is NOT created by this op." },
            "at": { "$ref": "#/$defs/point", "description": "Top-left corner [x, y] mil of the sheet box." },
            "size": { "$ref": "#/$defs/point", "description": "[width, height] mil of the sheet box." },
            "pins": {
              "type": "array",
              "description": "Sheet pins on the box edges; each pin's edge coordinate is at + offset_mil along its side, wire endpoints attach to that coordinate.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "enum": ["input", "output", "bidirectional", "tri_state", "passive"] },
                  "side": { "enum": ["left", "right", "top", "bottom"] },
                  "offset_mil": { "type": "number" }
                },
                "required": ["name", "type", "side", "offset_mil"],
                "additionalProperties": false
              }
            }
          },
          "required": ["op", "name", "file", "at", "size"],
          "description": "Emit a hierarchical (sheet ...) node with Sheetname/Sheetfile, sheet pins at computed edge coordinates and the (instances) block; the child file is authored separately."
        },
        {
          "properties": {
            "op": { "const": "set_title_block" },
            "title": { "type": "string" },
            "date": { "type": "string" },
            "rev": { "type": "string" },
            "company": { "type": "string" },
            "comment1": { "type": "string" },
            "comment2": { "type": "string" },
            "comment3": { "type": "string" },
            "comment4": { "type": "string" },
            "comment5": { "type": "string" },
            "comment6": { "type": "string" },
            "comment7": { "type": "string" },
            "comment8": { "type": "string" },
            "comment9": { "type": "string" }
          },
          "required": ["op"],
          "minProperties": 2,
          "description": "Set/replace title-block fields (at least one required). Find-or-create keeps the node where eeschema expects it (after paper, before lib_symbols); connectivity-neutral; unchanged values replay as a no-op note."
        },
        {
          "properties": {
            "op": { "const": "place_divider" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "top_net": { "type": "string" },
            "mid_net": { "type": "string" },
            "bottom_net": { "type": "string" },
            "designators": { "$ref": "#/$defs/strpair" },
            "values": { "$ref": "#/$defs/strpair" },
            "spacing_mil": { "type": "number" },
            "lib_id": { "type": "string" }
          },
          "required": ["op", "x_mil", "y_mil", "top_net", "mid_net", "bottom_net"]
        },
        {
          "properties": {
            "op": { "const": "place_decoupling" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "anchor": { "$ref": "#/$defs/anchorref" },
            "offset_mil": { "$ref": "#/$defs/point" },
            "power_net": { "type": "string" },
            "designator": { "type": "string" },
            "value": { "type": "string" },
            "gnd_net": { "type": "string" },
            "lib_id": { "type": "string" }
          },
          "required": ["op", "power_net"],
          "description": "Macro: one bypass cap + rail/gnd labels on its pins. Position is exactly one of x_mil+y_mil or anchor (+offset_mil) — e.g. anchor 'U1.VCC' drops the cap next to the pin it decouples."
        },
        {
          "properties": {
            "op": { "const": "place_pullup" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "anchor": { "$ref": "#/$defs/anchorref" },
            "offset_mil": { "$ref": "#/$defs/point" },
            "net": { "type": "string" },
            "rail_net": { "type": "string" },
            "designator": { "type": "string" },
            "value": { "type": "string" },
            "lib_id": { "type": "string" }
          },
          "required": ["op", "net", "rail_net"],
          "description": "Macro: one pull-up/-down resistor + labels. Position is exactly one of x_mil+y_mil or anchor (+offset_mil)."
        },
        {
          "properties": {
            "op": { "const": "place_led_indicator" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "net": { "type": "string" },
            "designators": { "$ref": "#/$defs/strpair" },
            "r_value": { "type": "string" },
            "gnd_net": { "type": "string" },
            "mid_net": { "type": "string" },
            "spacing_mil": { "type": "number" }
          },
          "required": ["op", "x_mil", "y_mil", "net"]
        },
        {
          "properties": {
            "op": { "const": "place_rc_filter" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "in_net": { "type": "string" },
            "out_net": { "type": "string" },
            "designators": { "$ref": "#/$defs/strpair" },
            "r_value": { "type": "string" },
            "c_value": { "type": "string" },
            "gnd_net": { "type": "string" },
            "spacing_mil": { "type": "number" }
          },
          "required": ["op", "x_mil", "y_mil", "in_net", "out_net"]
        },
        {
          "properties": {
            "op": { "const": "place_crystal" },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "in_net": { "type": "string" },
            "out_net": { "type": "string" },
            "designators": { "$ref": "#/$defs/strtriple" },
            "value": { "type": "string" },
            "load_c": { "type": "string" },
            "gnd_net": { "type": "string" },
            "spacing_mil": { "type": "number" }
          },
          "required": ["op", "x_mil", "y_mil", "in_net", "out_net"]
        },
        {
          "properties": {
            "op": { "const": "place_array" },
            "lib_id": { "type": "string" },
            "designator_prefix": { "type": "string" },
            "count": { "type": "integer", "minimum": 1, "maximum": 200 },
            "x_mil": { "type": "number" },
            "y_mil": { "type": "number" },
            "start_index": { "type": "integer", "minimum": 0 },
            "pitch_mil": { "type": "number" },
            "direction": { "enum": ["right", "down", "left", "up"] },
            "value": { "type": "string" },
            "values": { "type": "array", "items": { "type": "string" }, "minItems": 1,
                        "description": "Per-element values; length must equal count (checked at expansion)." },
            "rotation": { "$ref": "#/$defs/rotation" },
            "footprint": { "type": "string" }
          },
          "required": ["op", "lib_id", "designator_prefix", "count", "x_mil", "y_mil"],
          "description": "Macro: N identical parts in a row/column at a fixed pitch, named <prefix><start_index>.. — placement sugar; labels/wiring stay explicit."
        },
        {
          "properties": {
            "op": { "const": "connect_and_label" },
            "from": { "$ref": "#/$defs/endpoint" },
            "to": { "$ref": "#/$defs/endpoint" },
            "net": { "type": "string" },
            "orientation": { "$ref": "#/$defs/rotation" },
            "scope": { "$ref": "#/$defs/scope" }
          },
          "required": ["op", "from", "to", "net"],
          "description": "Macro: pin-to-pin wire + ONE net label mid-wire (the fix for facing-pin label collisions)."
        },
        {
          "properties": {
            "op": { "const": "place_pwr_flag" },
            "at": { "$ref": "#/$defs/anchor" },
            "rotation": { "$ref": "#/$defs/rotation" }
          },
          "required": ["op", "at"],
          "description": "Macro: power:PWR_FLAG placed MID-WIRE (on-pin placement overlaps symbol bodies); default rotation 90 turns the flag body off the wire axis."
        },
        {
          "properties": {
            "op": { "const": "terminate_unused_unit" },
            "designator": { "type": "string" },
            "lib_id": { "type": "string" },
            "unit": { "type": "integer", "minimum": 1 },
            "at": { "$ref": "#/$defs/point" },
            "in_plus": { "type": "string" },
            "in_minus": { "type": "string" },
            "out": { "type": "string" },
            "vcc": { "type": "string" },
            "gnd": { "type": "string" }
          },
          "required": ["op", "designator", "lib_id", "unit", "at", "in_plus", "in_minus", "out"],
          "description": "Macro: place an unused op-amp/comparator unit and terminate it (gnd on in_plus, vcc on in_minus, no-connect on out)."
        }
      ]
    }
  }
}
