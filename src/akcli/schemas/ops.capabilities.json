{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tipoLi5890/akcli/schemas/ops.capabilities.json",
  "title": "AkcliOpCapabilities",
  "protocol_version": 1,
  "description": "Per-executor support matrix. true = supported; false = ERROR: OP_UNSUPPORTED.",
  "executors": [
    "kicad",
    "altium"
  ],
  "altium_live_wired": false,
  "altium_live_note": "the 'altium' executor column describes the experimental Windows-only live bridge, which has no CLI wiring: plan/draw always build target_format 'kicad'. Do not select an Altium write target.",
  "ops": {
    "place_component": {
      "kicad": true,
      "altium": true,
      "notes": ""
    },
    "set_component_transform": {
      "kicad": true,
      "altium": true,
      "notes": "rotate/mirror existing component"
    },
    "set_component_parameters": {
      "kicad": true,
      "altium": true,
      "notes": "ref/value/footprint/params"
    },
    "add_wire": {
      "kicad": true,
      "altium": true,
      "notes": "orthogonal; may emit many segments"
    },
    "route_net": {
      "kicad": true,
      "altium": false,
      "notes": "deterministic L/Z auto-route, corner avoids pin tips; optional mid-wire label"
    },
    "add_junction": {
      "kicad": true,
      "altium": true,
      "notes": ""
    },
    "add_no_connect": {
      "kicad": true,
      "altium": true,
      "notes": ""
    },
    "add_net_label": {
      "kicad": true,
      "altium": true,
      "notes": "scope local|global|hierarchical"
    },
    "place_power_port": {
      "kicad": true,
      "altium": true,
      "notes": ""
    },
    "add_bus": {
      "kicad": true,
      "altium": false,
      "notes": "OP_UNSUPPORTED on Altium live v1"
    },
    "add_bus_entry": {
      "kicad": true,
      "altium": false,
      "notes": "OP_UNSUPPORTED on Altium live v1"
    },
    "add_text": {
      "kicad": true,
      "altium": true,
      "notes": "free angle allowed"
    },
    "add_rectangle": {
      "kicad": true,
      "altium": false,
      "notes": "top-level graphic (group frames); connectivity-neutral"
    },
    "add_text_box": {
      "kicad": true,
      "altium": false,
      "notes": "bordered multi-line note box; connectivity-neutral"
    },
    "set_title_block": {
      "kicad": true,
      "altium": false,
      "notes": "title/date/rev/company/comment1..9; >=1 field; connectivity-neutral"
    },
    "add_sheet": {
      "kicad": true,
      "altium": false,
      "notes": "hierarchical (sheet ...) node + sheet pins; child file authored separately. OP_UNSUPPORTED on Altium live v1"
    },
    "place_gnd": {
      "kicad": true,
      "altium": true,
      "notes": "sugar over place_power_port"
    },
    "place_vcc": {
      "kicad": true,
      "altium": true,
      "notes": "sugar over place_power_port"
    },
    "delete_component": {
      "kicad": true,
      "altium": false
    },
    "delete_object": {
      "kicad": true,
      "altium": false
    },
    "move_component": {
      "kicad": true,
      "altium": false
    },
    "rename_net": {
      "kicad": true,
      "altium": false,
      "notes": "rewrites label texts + power-port net Values; 0 matches = replay-safe note"
    }
  }
}
